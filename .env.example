# PostgreSQL credentials
POSTGRES_USER=temporal
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=temporal

# Temporal image versions (auto-setup and admin-tools share TEMPORAL_VERSION)
TEMPORAL_VERSION=1.29.6
TEMPORAL_UI_VERSION=2.51.1

# Comma-separated origins allowed by the Temporal UI (set to your Coolify domain in production)
TEMPORAL_CORS_ORIGINS=http://localhost:8080
